{
  "name": "Technical Evaluation",
  "image": "ghcr.io/event-driven-vision-school/event-driven-school:codespaces",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:latest": { },
    "ghcr.io/devcontainers/features/git-lfs:latest": { }
  },
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "vnc"
    }        
  },
  "remoteUser": "student",
  "customizations": {
    "codespaces": {
      "openFiles": ["README.md"]
    }
  },
  "postAttachCommand": {
    "vnc": "start-vnc-session.sh"
  }
}
